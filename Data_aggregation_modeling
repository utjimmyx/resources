           from = Sys.Date() - years(5), to = Sys.Date())


AMZN <- data.frame(
  AMZN,
  date = as.Date(rownames(data.frame(AMZN)))
)

#now let's predict Amazon stock price with Google Trends search queries "recipe" and "ecommerce," separately  
library(gtrendsR)
